numbers_list = []
count = int(input("Введите количество элементов в списке: "))
print("Введите элементы списка (по одному):")
for i in range(count):
    element = input(f"Элемент {i+1}: ")
    numbers_list.append(element)
power = int(input("Введине степень: "))
result_list = []
for item in numbers_list:
    if item.lstrip('-').isdigit():
        number = int(item)
        result = number ** power
        result_list.append(result)
    else:
        result = item * power
        result_list.append(result)
print("Вывод:", end=" ")
for i, value in enumerate(result_list):
    if i == len(result_list) - 1:
        print(value)
    else:
        print(value, end=" ")
